<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    ```
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Adicionar Figurinha"
            android:textSize="28sp"/>

        <EditText
            android:id="@+id/editNumero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Número da figurinha"
            android:inputType="number"/>

        <EditText
            android:id="@+id/editJogador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nome do jogador"/>

        <EditText
            android:id="@+id/editSelecao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Seleção"/>

        <Spinner
            android:id="@+id/spinnerRaridade"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <CheckBox
            android:id="@+id/checkTenho"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tenho a figurinha"/>

        <CheckBox
            android:id="@+id/checkColada"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Já colei no álbum"/>

        <CheckBox
            android:id="@+id/checkRepetida"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="É repetida"/>

        <Button
            android:id="@+id/btnSalvar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Salvar Figurinha"/>

    </LinearLayout>
    ```

</ScrollView>
